{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2019",
    "lib": ["es2019", "dom"],
    "sourceMap": true,
    "allowJs": true,
    "jsx": "react",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"]
    },
    "strict": true,
    //Todo: Endre til true under og legg inn returntyper i sagas
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "build", "scripts", "acceptance-tests", "jest"],
  "types": ["typePatches"]
}
