{
  "name": "syfomodiaperson",
  "version": "0.0.1",
  "description": "Digitalisering av sykefraværsoppfølging",
  "license": "ISC",
  "author": "Team DigiSyfo <digisyfo@nav.no>",
  "type": "module",
  "main": "index.tsx",
  "scripts": {
    "start": "pnpm msw:update && vite",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build",
    "build:server": "tsc --build ./server/tsconfig.json",
    "test": "vitest run",
    "lint-and-typecheck": "pnpm lint:check && pnpm typecheck",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint:check": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt:write": "oxfmt --write",
    "fmt:check": "oxfmt --check",
    "prepare": "husky install || true",
    "msw:update": "msw init . --save"
  },
  "dependencies": {
    "@grafana/faro-react": "2.8.2",
    "@grafana/faro-web-sdk": "2.8.2",
    "@grafana/faro-web-tracing": "2.8.2",
    "@navikt/aksel-icons": "8.15.0",
    "@navikt/analytics-types": "0.0.9",
    "@navikt/ds-css": "8.15.0",
    "@navikt/ds-react": "8.15.0",
    "@navikt/ds-tailwind": "8.15.0",
    "@navikt/lumi-survey": "^0.4.0",
    "@navikt/pino-logger": "5.0.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-query-devtools": "5.101.2",
    "@types/express": "5.0.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/recharts": "1.8.29",
    "@types/styled-components": "5.1.36",
    "@types/umami": "2.10.1",
    "axios": "1.18.1",
    "classnames": "2.5.1",
    "dayjs": "1.11.21",
    "dotenv": "16.5.0",
    "express": "5.2.1",
    "helmet": "4.6.0",
    "pino": "10.3.1",
    "prom-client": "11.5.3",
    "react": "19.2.7",
    "react-collapse": "5.1.1",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "react-router-dom": "6.30.4",
    "recharts": "2.15.3",
    "redis": "5.11.0",
    "styled-components": "5.3.6",
    "unleash-client": "6.11.1",
    "use-debounce": "10.1.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.13.10",
    "@types/react-document-title": "2.0.10",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.5.2",
    "eslint-plugin-no-only-tests": "3.4.0",
    "husky": "8.0.3",
    "jsdom": "26.1.0",
    "less": "4.6.7",
    "lint-staged": "13.2.1",
    "msw": "2.15.0",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "pino-pretty": "13.1.3",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md,less,html}": [
      "pnpm fmt:check"
    ]
  },
  "packageManager": "pnpm@11.1.3",
  "msw": {
    "workerDirectory": [
      ""
    ]
  }
}
